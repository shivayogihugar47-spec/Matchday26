# Server
PORT=3001

# OpenRouter (Get your key from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vapi (Get your keys from https://vapi.ai/)
VITE_VAPI_PUBLIC_KEY=your_vapi_public_key_here
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# Football Data API (optional, for real match data from football-data.org)
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here
